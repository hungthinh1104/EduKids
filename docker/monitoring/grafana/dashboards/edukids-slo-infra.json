    {
      "type": "timeseries",
      "title": "Request Rate by Route",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum by (route) (rate(edukids_http_requests_total[5m])) or vector(0)", "legendFormat": "{{route}}"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "timeseries",
      "title": "Latency by Quantile",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.5, sum(rate(edukids_http_request_duration_seconds_bucket[5m])) by (le)) or vector(0)", "legendFormat": "P50"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum(rate(edukids_http_request_duration_seconds_bucket[5m])) by (le)) or vector(0)", "legendFormat": "P95"},
        {"refId": "C", "expr": "histogram_quantile(0.99, sum(rate(edukids_http_request_duration_seconds_bucket[5m])) by (le)) or vector(0)", "legendFormat": "P99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "bargauge",
      "title": "Top 10 Routes by P95",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "topk(10, histogram_quantile(0.95, sum(rate(edukids_http_request_duration_seconds_bucket[5m])) by (le, route))) or vector(0)", "legendFormat": "{{route}}"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true}
    },
    {
      "type": "timeseries",
      "title": "4xx vs 5xx Ratio",
      "id": 8,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum(rate(edukids_http_requests_total{status_code=~\"4..\"}[5m])) / clamp_min(sum(rate(edukids_http_requests_total[5m])), 1) or vector(0)", "legendFormat": "4xx ratio"},
        {"refId": "B", "expr": "sum(rate(edukids_http_requests_total{status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(edukids_http_requests_total[5m])), 1) or vector(0)", "legendFormat": "5xx ratio"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
