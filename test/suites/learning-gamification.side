{
  "id": "fc1a2b3c-4d5e-6f78-90ab-cdef12345678",
  "version": "2.0",
  "name": "EduKids Learning and Gamification",
  "url": "http://localhost:3000",
  "tests": [
    {
      "id": "learn0001-aaaa-bbbb-cccc-dddddddddd01",
      "name": "Play_Unauth_ShouldRedirectToLogin",
      "commands": [
        {
          "id": "learn1111-0000-0000-0000-000000000001",
          "comment": "TEST 009 - Trang /play khi chưa đăng nhập phải redirect",
          "command": "open",
          "target": "/",
          "targets": [],
          "value": ""
        },
        {
          "id": "learn1111-0000-0000-0000-000000000002",
          "command": "runScript",
          "target": "document.cookie.split(';').forEach(function(c){document.cookie=c.replace(/^ +/,'').replace(/=.*/, '=;expires='+new Date(0).toUTCString()+';path=/');}); localStorage.clear(); sessionStorage.clear();",
          "targets": [],
          "value": ""
        },
        {
          "id": "learn1111-0000-0000-0000-000000000003",
          "command": "open",
          "target": "/play",
          "targets": [],
          "value": ""
        },
        {
          "id": "learn1111-0000-0000-0000-000000000004",
          "command": "waitForElementPresent",
          "target": "css=body",
          "targets": [],
          "value": "10000"
        },
        {
          "id": "learn1111-0000-0000-0000-000000000005",
          "comment": "Phải bị redirect về /login",
          "command": "runScript",
          "target": "if(!window.location.pathname.includes('/login')) throw new Error('Expected /login redirect for unauthenticated /play, got '+window.location.href);",
          "targets": [],
          "value": ""
        }
      ]
    },
