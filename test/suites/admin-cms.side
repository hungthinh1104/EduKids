        },
        {
          "id": "cms22222-0000-0000-0000-000000000003",
          "command": "open",
          "target": "/admin/media",
          "targets": [],
          "value": ""
        },
        {
          "id": "cms22222-0000-0000-0000-000000000004",
          "command": "waitForElementPresent",
          "target": "css=body",
          "targets": [],
          "value": "10000"
