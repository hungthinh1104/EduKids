{
  "id": "ab123456-cd78-90ef-ab12-34567890abcd",
  "version": "2.0",
  "name": "EduKids Admin CMS",
  "url": "http://localhost:3000",
  "tests": [
    {
      "id": "cms00001-aaaa-bbbb-cccc-dddddddddd01",
      "name": "AdminDashboard_Unauth_ShouldRedirectLogin",
      "commands": [
        {
          "id": "cms11111-0000-0000-0000-000000000001",
          "comment": "TEST 007 - Admin dashboard khi chưa đăng nhập phải redirect về /login",
          "command": "open",
          "target": "/",
          "targets": [],
          "value": ""
        },
        {
          "id": "cms11111-0000-0000-0000-000000000002",
          "command": "runScript",
          "target": "document.cookie.split(';').forEach(function(c){document.cookie=c.replace(/^ +/,'').replace(/=.*/, '=;expires='+new Date(0).toUTCString()+';path=/');}); localStorage.clear(); sessionStorage.clear();",
          "targets": [],
          "value": ""
        },
        {
          "id": "cms11111-0000-0000-0000-000000000003",
          "command": "open",
          "target": "/admin",
          "targets": [],
          "value": ""
        },
        {
          "id": "cms11111-0000-0000-0000-000000000004",
          "command": "waitForElementPresent",
          "target": "css=body",
          "targets": [],
          "value": "10000"
        },
        {
          "id": "cms11111-0000-0000-0000-000000000005",
          "command": "runScript",
          "target": "if(!window.location.pathname.includes('/login')) throw new Error('Expected /login redirect from /admin, got '+window.location.href);",
          "targets": [],
          "value": ""
        }
      ]
    },
    {
      "id": "cms00002-aaaa-bbbb-cccc-dddddddddd02",
