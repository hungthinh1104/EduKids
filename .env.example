# Root env example for Docker Compose only
# App runtime env files:
# - apps/backend/.env.development
# - apps/backend/.env.production
# - apps/frontend/.env.development
# - apps/frontend/.env.production

NODE_ENV=development

# Containers
DB_USER=edukids
DB_PASSWORD=change_me_strong_db_password
DB_NAME=edukids_db
BACKEND_PORT=3001
REDIS_PASSWORD=change_me_strong_redis_password
REDIS_HOST=redis
REDIS_PORT=6379

# Backend public URLs / CORS
FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGIN=https://your-frontend-domain.com
PUBLIC_API_BASE_URL=https://your-backend-domain.com/api
APP_HOST=0.0.0.0

# App secrets used by compose services
JWT_SECRET=change_me_super_secret_jwt_key_min_32_chars
JWT_EXPIRY=24h
ADMIN_SEED_PASSWORD=change_me_seed_admin_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@edukids.com
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DEBUG_ENDPOINT_ENABLED=false

# Frontend endpoint overrides for compose
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Monitoring stack (Grafana)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# ===== Security =====
# Set METRICS_TOKEN to protect /api/metrics in production (leave blank to disable check in dev)
METRICS_TOKEN=
# Set BIND_HOST=127.0.0.1 in production when using nginx reverse proxy (default 0.0.0.0 for dev)
BIND_HOST=0.0.0.0
